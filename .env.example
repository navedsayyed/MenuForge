# Appwrite Configuration
# Replace these values with your actual Appwrite project details

# Appwrite Endpoint (e.g., https://cloud.appwrite.io/v1 or your self-hosted URL)
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Your Appwrite Project ID (found in Appwrite Console)
EXPO_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here

# Your Database ID
EXPO_PUBLIC_APPWRITE_DATABASE_ID=your_database_id_here

# Collection IDs
EXPO_PUBLIC_APPWRITE_RESTAURANTS_COLLECTION_ID=restaurants
EXPO_PUBLIC_APPWRITE_DISHES_COLLECTION_ID=dishes

# Storage Bucket ID
EXPO_PUBLIC_APPWRITE_BUCKET_ID=dish-images
